DATABASE_URL="file:./dev.db"

JWT_SECRET="replace-with-strong-random-secret"

SMTP_HOST="smtp.example.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="mailer@example.com"
SMTP_PASS="replace-with-app-password"

FRONTEND_URL="http://127.0.0.1:3000"

# Buffered telemetry replay safety
RTK_BUFFER_REPLAY_ENABLED=1
TELEMETRY_BUFFER_REPLAY_DEBOUNCE_MS=1800000
RTK_BUFFER_DRAINED_REPLAY_DEBOUNCE_MS=30000
REPLAY_WRITER_DRAIN_TIMEOUT_MS=60000
REPLAY_FAILURE_BACKOFF_MS=60000
REPLAY_TRANSACTION_TIMEOUT_MS=1800000
REPLAY_TRANSACTION_MAX_WAIT_MS=60000
